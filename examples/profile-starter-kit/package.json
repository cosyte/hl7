{
  "name": "@{{YOUR_ORG}}/hl7-profile-{{PROFILE_NAME}}",
  "version": "0.1.0",
  "description": "HL7 profile package for {{YOUR_ORG}} integrations, built with @cosyte/hl7.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE", "CUSTOMIZING.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "prettier": "@cosyte/prettier-config",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,md}\" \"test/**/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,md}\" \"test/**/*.ts\" \"*.{json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "attw": "attw --pack .",
    "clean": "rm -rf dist coverage",
    "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm attw"
  },
  "peerDependencies": {
    "@cosyte/hl7": ">=0.0.0"
  },
  "peerDependenciesMeta": {
    "@cosyte/hl7": {
      "optional": false
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "@cosyte/eslint-config": "^0.0.3",
    "@cosyte/hl7": "file:../..",
    "@cosyte/prettier-config": "^0.0.2",
    "@cosyte/tsconfig": "^0.0.2",
    "@cosyte/tsup-config": "^0.0.1",
    "@cosyte/vitest-config": "^0.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "10.5.0",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "4.1.4"
  }
}
